# LLM provider — AWS Bedrock.
AWS_PROFILE=your-profile
AWS_REGION=us-west-2

# Teams Bot registration credentials (Azure portal → Bot registration → Configuration).
# TEAMS_APP_ID / TEAMS_TENANT_ID: configure INBOUND Bot Framework JWT verification
#   (the audience + tenant an incoming Teams activity's token must match).
# TEAMS_APP_PASSWORD: the client secret, used ONLY for the OUTBOUND OAuth 2.0
#   client-credentials token fetch in src/lib/teams-client.ts (posting replies).
#   It is never passed to createTeamsChannel. See README "How to test this".
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=
TEAMS_TENANT_ID=

# Optional — override Bot Framework defaults (leave blank for public Azure AD):
TEAMS_OAUTH_AUTHORITY=
TEAMS_OPENID_METADATA_URL=
TEAMS_TOKEN_ISSUER=

# Daytona — per-conversation remote sandbox.
DAYTONA_API_KEY=
DAYTONA_SNAPSHOT=teams-assistant-skills:v1
