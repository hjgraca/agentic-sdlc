# Copy to .env and fill in real values. Never commit real secrets.
# In GitHub Actions these come from repo Secrets/Variables, not this file.

# LLM provider — AWS Bedrock (model amazon-bedrock/us.anthropic.claude-sonnet-4-6).
# Locally, AWS_PROFILE resolves credentials. In GitHub Actions there is no stored
# key: the workflow assumes a Bedrock-only IAM role via GitHub OIDC, which exports
# short-lived AWS_* env vars (see .github/workflows/implement.yml).
AWS_PROFILE=your-profile
AWS_REGION=us-west-2

# GitHub. Locally, use a PAT with `repo` scope (read the issue/spec, create a
# branch + push, open a PR, comment) so the agent can build and open the PR. In
# Actions this is the built-in GITHUB_TOKEN, scoped by the workflow's
# permissions: block (contents + pull-requests + issues write). The agent's
# shell reads it as GH_TOKEN/GITHUB_TOKEN (forwarded into the sandbox).
GITHUB_TOKEN=
# Optional — only for GitHub Enterprise Server. Actions sets this automatically;
# Octokit defaults to https://api.github.com when unset.
# GITHUB_API_URL=https://github.example.com/api/v3
