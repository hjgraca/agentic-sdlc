# Copy to .env and fill in real values. Never commit real secrets.

# LLM provider — AWS Bedrock (model amazon-bedrock/us.anthropic.claude-sonnet-4-6).
# Locally, AWS_PROFILE resolves credentials; in-cluster they come from IRSA.
AWS_PROFILE=your-profile
AWS_REGION=us-west-2

# Jira + Confluence (same Atlassian Cloud site, shared basic-auth credentials)
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@your-org.com
JIRA_API_TOKEN=

# GitLab (cloud)
GITLAB_BASE_URL=https://gitlab.com/api/v4
GITLAB_TOKEN=

# Shared secret the Jira webhook must send as the x-webhook-secret header (or ?secret=)
JIRA_WEBHOOK_SECRET=
