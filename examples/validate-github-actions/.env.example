# Local runs only. In GitHub Actions these come from the workflow:
# GITHUB_TOKEN from the built-in Actions token, AWS creds via OIDC.

# A PAT (or fine-grained token) with pull-requests: read+write on the repo.
# Read: to fetch the PR diff and the linked spec issue.
# Write: to submit the verdict review on the PR.
GITHUB_TOKEN=ghp_xxx

# Only for GitHub Enterprise Server. Leave unset for github.com.
# GITHUB_API_URL=https://ghe.example.com/api/v3

# Bedrock model access (local runs). In Actions this is via OIDC, no keys.
AWS_REGION=us-east-1
