# Copy to .env and fill in real values. Never commit real secrets.

# LLM provider — AWS Bedrock (model amazon-bedrock/us.anthropic.claude-sonnet-4-6).
# Locally, AWS_PROFILE resolves credentials; on a host with no IAM role, use
# static AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY instead.
AWS_PROFILE=your-profile
AWS_REGION=us-west-2

# Slack app credentials (from the Slack app's "Basic Information" / "OAuth" pages).
# SLACK_SIGNING_SECRET verifies the exact request bytes of every inbound webhook.
# SLACK_BOT_TOKEN (xoxb-…) authenticates outbound Web API calls (chat.postMessage).
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# Daytona — the agent's per-thread remote sandbox (where it runs commands/code).
# DAYTONA_API_KEY authenticates the SDK. DAYTONA_SNAPSHOT names a prebuilt
# snapshot that already contains AGENTS.md + .agents/skills/ at the box's work
# dir, because Flue discovers skills from the SANDBOX filesystem, not this host.
# Leave DAYTONA_SNAPSHOT unset to use Daytona's default image (no baked skills —
# the agent then runs framing/skill-free; fine for a quick smoke test).
DAYTONA_API_KEY=
DAYTONA_SNAPSHOT=slack-assistant-skills:v1
