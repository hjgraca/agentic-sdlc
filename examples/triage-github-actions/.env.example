# Copy to .env and fill in real values. Never commit real secrets.
# In GitHub Actions these come from repo Secrets/Variables, not this file.

# LLM provider — AWS Bedrock (model amazon-bedrock/us.anthropic.claude-sonnet-4-6).
# Locally, AWS_PROFILE resolves credentials. In GitHub Actions there is no IAM
# role on a hosted runner, so CI uses static AWS_ACCESS_KEY_ID /
# AWS_SECRET_ACCESS_KEY from repo secrets instead (see .github/workflows/triage.yml).
AWS_PROFILE=your-profile
AWS_REGION=us-west-2

# GitHub. Locally, use a PAT with `repo` scope (read code + issues) so the agent
# can read files and post the triage comment. In Actions this is the built-in
# GITHUB_TOKEN, scoped by the workflow's permissions: block.
GITHUB_TOKEN=
# Optional — only for GitHub Enterprise Server. Actions sets this automatically;
# Octokit defaults to https://api.github.com when unset.
# GITHUB_API_URL=https://github.example.com/api/v3
