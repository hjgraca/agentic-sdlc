# Copy to .env and fill in real values. Never commit real secrets.

# LLM provider — AWS Bedrock (model amazon-bedrock/us.anthropic.claude-sonnet-4-6).
# Locally, AWS_PROFILE resolves credentials; on Lambda they come from the
# function's execution role (attach AmazonBedrockFullAccess or a scoped policy).
AWS_PROFILE=your-profile
AWS_REGION=us-west-2

# Linear credentials: use the bot user's personal API key (stable).
# Upgrade path: replace with LINEAR_ACCESS_TOKEN for OAuth app actor.
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxx

# HMAC-SHA256 signing secret configured on the Linear webhook.
LINEAR_WEBHOOK_SECRET=

# Optional: pin to a single Linear organization (payload mismatches → 403).
# LINEAR_ORGANIZATION_ID=

# Optional: pin to a single Linear webhook id (payload mismatches → 403).
# LINEAR_WEBHOOK_ID=
